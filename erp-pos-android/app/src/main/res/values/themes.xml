<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ErpPos" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_purple_dark</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@color/card_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="materialCardViewStyle">@style/Widget.ErpPos.Card</item>
        <item name="materialButtonStyle">@style/Widget.ErpPos.Button</item>
    </style>

    <style name="Widget.ErpPos.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_color</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.ErpPos.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btn_gradient</item>
        <item name="backgroundTint">@null</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.ErpPos.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_color</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.ErpPos.Button.Outlined.Checked" parent="Widget.ErpPos.Button.Outlined">
        <item name="strokeColor">@color/accent_purple</item>
        <item name="backgroundTint">@color/purple_tint</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
