# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://autohub:autohub_secret@localhost:5432/autohub_bd?schema=public

# Redis (optional — for future cart/session cache)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins (required in production)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# JWT — use long random strings (min 32 chars) in production
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed admin (development only — change in production)
ADMIN_SEED_EMAIL=admin@autohub.bd
ADMIN_SEED_PASSWORD=AutoHub@Admin2026

# Dev helpers
ALLOW_DEV_VERIFICATION_CODE=false
